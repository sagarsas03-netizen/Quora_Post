<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>POST DETAIL</title>
</head>
<body>
    <h1>HERE IS YOUR POST DETAIL</h1>
    <p>Post id: <%= post.id %></p>
    <div class="post">
        <h3 class="user">@<%= post.username%></h3>
        <h5 class="content"><%=post.content%></h5>
    </div>
</body>
</html>