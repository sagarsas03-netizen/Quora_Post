<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALL POST</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quara Post</h1>
    <% for (post of  posts){ %>
         
         <div class="post">
            <h3 class="user">@ <%= post.username %></h3>
            <h5 class="content"><%= post.content %></h5>
            <br/>
            <a href="http://localhost:8080/posts/<%=post.id%>">show details</a>
            <a href="http://localhost:8080/posts/<%=post.id%>/edit">Edit</a>
            <form action="/posts/<%=post.id%>?_method=DELETE" method="post">
                <button>Delete Post</button>
            </form>

            
         </div>
     <%  } %>

     <br/>
     <br/>
     <a href="http://localhost:8080/posts/new">Create New Post</a>

</body>
</html>

